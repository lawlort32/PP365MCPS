# Dataverse MCP Server Configuration
# Copy this file to .env and fill in your actual values

# Your Dataverse environment URL
DATAVERSE_URL=https://your-org.crm.dynamics.com

# Authentication mode: client_secret (default), obo, public_client, broker
DATAVERSE_AUTH_MODE=client_secret

# Azure App Registration details
DATAVERSE_CLIENT_ID=your-client-id-here
DATAVERSE_CLIENT_SECRET=your-client-secret-here
DATAVERSE_TENANT_ID=your-tenant-id-here

# Optional for OBO mode: incoming user assertion token from MCP host/gateway
# DATAVERSE_OBO_ASSERTION=eyJ...

# Optional: Enable debug logging
# DEBUG=true
